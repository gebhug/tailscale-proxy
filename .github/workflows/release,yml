# Workflow: erstellt bei Push in main einen neuen Release v1.0.x und einen Tag
name: Create v1.0.x release on push to main

on:
  push:
    branches:
      - main

permissions:
  contents: write  # nötig, um Tags/Releases anzulegen

jobs:
  create-release:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Determine next v1.0.x, create tag and release
        uses: actions/github-script@v6
        with:
          script: |
            const core = require('@actions/core');

            const owner = context.repo.owner;
            const repo = context.repo.repo;
            const perPage = 100;

            // 1) Ermittle höchste vorhandene v1.0.x Release-Nummer
            let max = -1;
            let page = 1;
            while (true) {
              const releases = await github.rest.repos.listReleases({
                owner,
                repo,
                per_page: perPage,
                page
              });
              if (!releases || !releases.data || releases.data.length === 0) break;
              for (const r of releases.data) {
                const m = /^v1\.0\.(\d+)$/.exec(r.tag_name);
                if (m) {
                  const n = parseInt(m[1], 10);
                  if (!Number.isNaN(n) && n > max) max = n;
                }
              }
              if (releases.data.length < perPage) break;
              page++;
            }

            // 2) Nächste Nummer (falls nichts vorhanden -> 1)
            let next = (max >= 0) ? max + 1 : 1;
            let tag = `v1.0.${next}`;

            // 3) Falls Tag bereits existiert (z.B. Race), weiter inkrementieren bis freier Tag
            // (Abfangen existierender git refs)
            while (true) {
              try {
                await github.rest.git.getRef({
                  owner,
                  repo,
                  ref: `refs/tags/${tag}`
                });
                // existiert -> inkrementieren und prüfen erneut
                core.info(`Tag ${tag} exists, incrementing...`);
                next++;
                tag = `v1.0.${next}`;
              } catch (err) {
                if (err.status === 404) {
                  // nicht gefunden -> frei zum anlegen
                  break;
                } else {
                  throw err;
                }
              }
            }

            // 4) Erstelle Tag (lightweight ref) auf dem aktuellen Commit und erstelle Release
            await github.rest.git.createRef({
              owner,
              repo,
              ref: `refs/tags/${tag}`,
              sha: context.sha
            });

            const release = await github.rest.repos.createRelease({
              owner,
              repo,
              tag_name: tag,
              name: tag,
              body: `Automatisch erstellter Release ${tag}`,
              draft: false,
              prerelease: false
            });

            core.info(`Created tag ${tag} and release ${release.data.html_url}`);
            return { tag };
